#!/usr/bin/env python3
"""morvox — toggle audio capture, transcribe with whisper.cpp, type into a target window.

First invocation starts recording; second invocation stops recording,
transcribes the audio with whisper-cli, and types the result into a safe
target window for the current backend.
"""

import os
import sys

# Add src/ to sys.path so `from morvox import …` works
# regardless of how the script is invoked.
_src = os.path.join(os.path.dirname(os.path.abspath(__file__)), "src")
if os.path.isdir(_src):
    sys.path.insert(0, _src)

from morvox.__main__ import main

sys.exit(main())
