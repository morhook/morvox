#!/usr/bin/env python3
"""morvox — toggle audio capture, transcribe with whisper.cpp, type into focused window.

First invocation starts recording with parecord; second invocation stops recording,
transcribes the audio with whisper-cli, re-focuses the originally focused window,
and types the result via `xdotool type`.
"""

import argparse
import os
import re
import shutil
import signal
import subprocess
import sys
import time
from pathlib import Path

# --- Constants ---------------------------------------------------------------

def _resolve_whisper_dir() -> str:
    """Locate the whisper.cpp install directory.

    Resolution order:
      1. $MORVOX_WHISPER_DIR (if set)
      2. ~/.local/share/whisper.cpp (if it exists)
      3. ~/soft/whisper.cpp (legacy fallback)
    """
    env = os.environ.get("MORVOX_WHISPER_DIR")
    if env:
        return os.path.expanduser(env)
    home = os.path.expanduser("~")
    primary = os.path.join(home, ".local", "share", "whisper.cpp")
    if os.path.isdir(primary):
        return primary
    return os.path.join(home, "soft", "whisper.cpp")


WHISPER_DIR = _resolve_whisper_dir()
WHISPER_BIN = f"{WHISPER_DIR}/build/bin/whisper-cli"
DEFAULT_MODEL = f"{WHISPER_DIR}/models/ggml-base.en.bin"
STATE_DIR = os.environ.get("MORVOX_STATE_DIR", "/tmp/morvox")

# Noise tokens whisper sometimes outputs for empty/silent input.
_NOISE_TOKENS = {
    "[blank_audio]",
    "[ silence ]",
    "(silence)",
    "[silence]",
    "[music]",
    "[ music ]",
}

APP_NAME = "morvox"


# --- Small helpers -----------------------------------------------------------

def _state() -> Path:
    p = Path(STATE_DIR)
    p.mkdir(parents=True, exist_ok=True)
    return p


def _pid_file() -> Path:
    return _state() / "rec.pid"


def _target_file() -> Path:
    return _state() / "target_window"


def _wav_file() -> Path:
    return _state() / "rec.wav"


def _txt_file() -> Path:
    return _state() / "rec.txt"


def _log_file() -> Path:
    return _state() / "parecord.log"


def _whisper_log() -> Path:
    return _state() / "whisper.log"


def notify(summary: str, body: str = "") -> None:
    """Best-effort desktop notification; never fails the run."""
    if not shutil.which("notify-send"):
        return
    try:
        cmd = ["notify-send", "-a", APP_NAME, summary]
        if body:
            cmd.append(body)
        subprocess.run(cmd, check=False,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def die(msg: str, code: int = 1) -> None:
    print(f"morvox: {msg}", file=sys.stderr)
    notify("morvox error", msg)
    sys.exit(code)


def require_tool(name: str) -> str:
    path = shutil.which(name)
    if not path:
        die(f"required tool not found: {name}")
    return path


def pid_alive(pid: int) -> bool:
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        # Process exists but is owned by someone else.
        return True
    return True


def read_pid() -> int | None:
    pf = _pid_file()
    if not pf.exists():
        return None
    try:
        pid = int(pf.read_text().strip())
    except (ValueError, OSError):
        return None
    return pid if pid > 0 else None


def is_recording() -> bool:
    pid = read_pid()
    return pid is not None and pid_alive(pid)


def cleanup_state(keep_temp: bool = False) -> None:
    if keep_temp:
        return
    for p in (_pid_file(), _target_file(), _wav_file(), _txt_file()):
        try:
            p.unlink(missing_ok=True)
        except OSError:
            pass


# --- Start / Stop ------------------------------------------------------------

def cmd_start(args: argparse.Namespace) -> int:
    require_tool("parecord")
    require_tool("xdotool")

    state = _state()

    # Stale lock handling: if pid file exists but process is dead, clean up.
    existing = read_pid()
    if existing is not None and not pid_alive(existing):
        _pid_file().unlink(missing_ok=True)

    # Capture currently focused window id.
    try:
        win = subprocess.run(
            ["xdotool", "getactivewindow"],
            check=True, capture_output=True, text=True
        ).stdout.strip()
    except subprocess.CalledProcessError as e:
        die(f"xdotool getactivewindow failed: {e.stderr.strip()}")
        return 1  # unreachable

    if not win:
        die("xdotool returned an empty window id")

    _target_file().write_text(win + "\n")

    # Build parecord command. Use system default source unless overridden.
    parecord_cmd = [
        "parecord",
        "--channels=1",
        "--rate=16000",
        "--format=s16le",
        "--file-format=wav",
    ]
    if args.source:
        parecord_cmd += ["-d", args.source]
    parecord_cmd.append(str(_wav_file()))

    # Truncate previous log.
    log_path = _log_file()
    log_fd = open(log_path, "wb")

    try:
        proc = subprocess.Popen(
            parecord_cmd,
            stdout=log_fd,
            stderr=log_fd,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
            close_fds=True,
        )
    except FileNotFoundError:
        log_fd.close()
        die("parecord not found")
        return 1
    finally:
        # The child has inherited the fd; safe to close ours.
        try:
            log_fd.close()
        except Exception:
            pass

    # Give parecord a brief moment to fail fast (e.g. bad source).
    time.sleep(0.1)
    if proc.poll() is not None:
        # It died immediately.
        try:
            log_text = log_path.read_text(errors="replace").strip()
        except OSError:
            log_text = ""
        cleanup_state()
        die(f"parecord failed to start (exit {proc.returncode}). Log: {log_text}")

    _pid_file().write_text(f"{proc.pid}\n")
    notify("Recording…", "morvox is listening")
    print(f"recording (pid={proc.pid})")
    return 0


def stop_recorder(pid: int, timeout: float = 2.0) -> bool:
    """Send SIGINT, then SIGTERM if needed. Return True if process exited."""
    try:
        os.kill(pid, signal.SIGINT)
    except ProcessLookupError:
        return True
    except PermissionError:
        # Can't signal it; treat as not-our-problem.
        return False

    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if not pid_alive(pid):
            return True
        time.sleep(0.05)

    # Escalate.
    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        return True

    deadline = time.monotonic() + 1.0
    while time.monotonic() < deadline:
        if not pid_alive(pid):
            return True
        time.sleep(0.05)

    # Last resort.
    try:
        os.kill(pid, signal.SIGKILL)
    except ProcessLookupError:
        return True
    return not pid_alive(pid)


def clean_transcript(raw: str) -> str:
    # Collapse all whitespace runs (including newlines) into single spaces.
    return re.sub(r"\s+", " ", raw).strip()


def is_noise(text: str) -> bool:
    if not text:
        return True
    return text.strip().lower() in _NOISE_TOKENS


def cmd_stop(args: argparse.Namespace) -> int:
    require_tool("xdotool")

    pid = read_pid()
    if pid is None or not pid_alive(pid):
        # Nothing to stop. Treat as a no-op fresh state.
        cleanup_state()
        notify("morvox", "not recording")
        print("not recording", file=sys.stderr)
        return 0

    if not stop_recorder(pid):
        die("failed to stop recorder")

    # Recorder is done; pid file no longer relevant.
    _pid_file().unlink(missing_ok=True)

    wav = _wav_file()
    if not wav.exists() or wav.stat().st_size == 0:
        cleanup_state(keep_temp=args.keep_temp)
        die("no audio captured (empty wav)")

    # Verify whisper-cli & model.
    if not Path(WHISPER_BIN).exists():
        die(f"whisper-cli not found at {WHISPER_BIN}")
    model_path = args.model
    if not Path(model_path).exists():
        die(f"whisper model not found: {model_path}")

    out_prefix = str(_state() / "rec")  # whisper writes <prefix>.txt

    whisper_cmd = [
        WHISPER_BIN,
        "-m", model_path,
        "-f", str(wav),
        "-l", args.language,
        "-t", str(args.threads),
        "-nt",
        "-np",
        "-otxt",
        "-of", out_prefix,
    ]

    notify("Transcribing…")
    try:
        result = subprocess.run(
            whisper_cmd,
            capture_output=True,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        cleanup_state(keep_temp=args.keep_temp)
        die("whisper-cli not executable")
        return 1

    # Persist whisper log for debugging.
    try:
        _whisper_log().write_text(
            f"--- stdout ---\n{result.stdout}\n--- stderr ---\n{result.stderr}\n"
        )
    except OSError:
        pass

    if result.returncode != 0:
        err = (result.stderr or "").strip()
        notify("Transcription failed", err[:200] if err else "whisper-cli error")
        print(f"morvox: whisper-cli failed (exit {result.returncode})", file=sys.stderr)
        if err:
            print(err, file=sys.stderr)
        # Leave temp around for debugging unless keep-temp explicitly false?
        # User asked to delete on success only; failure -> keep for debugging.
        return result.returncode

    txt = _txt_file()
    if not txt.exists():
        notify("Transcription produced no output")
        die("whisper produced no .txt file")

    raw = txt.read_text(errors="replace")
    text = clean_transcript(raw)

    if is_noise(text):
        notify("Empty recording")
        cleanup_state(keep_temp=args.keep_temp)
        return 0

    # Re-focus original window.
    target = ""
    tf = _target_file()
    if tf.exists():
        target = tf.read_text().strip()

    refocused = False
    if target:
        try:
            subprocess.run(
                ["xdotool", "windowactivate", "--sync", target],
                check=True, capture_output=True, text=True, timeout=3,
            )
            refocused = True
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
            err = getattr(e, "stderr", "") or ""
            print(
                f"morvox: warning: could not re-focus window {target}: "
                f"{err.strip() if isinstance(err, str) else err}; "
                "typing into currently focused window instead.",
                file=sys.stderr,
            )

    # Type text. Pass as single argv element to avoid quoting issues.
    type_cmd = [
        "xdotool", "type",
        "--delay", str(args.type_delay),
        "--clearmodifiers",
        "--", text,
    ]
    try:
        subprocess.run(type_cmd, check=True)
    except subprocess.CalledProcessError as e:
        die(f"xdotool type failed: {e}")

    notify("Typed transcription", text[:120] + ("…" if len(text) > 120 else ""))
    cleanup_state(keep_temp=args.keep_temp)
    if not refocused and target:
        return 0  # warning already emitted
    return 0


# --- Sub-actions: --status, --cancel ----------------------------------------

def cmd_status() -> int:
    print("recording" if is_recording() else "idle")
    return 0


def cmd_cancel(args: argparse.Namespace) -> int:
    pid = read_pid()
    if pid is None or not pid_alive(pid):
        cleanup_state()
        print("not recording")
        return 0
    stop_recorder(pid)
    cleanup_state(keep_temp=args.keep_temp)
    notify("Recording cancelled")
    print("cancelled")
    return 0


# --- argparse / dispatch -----------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    default_threads = max(1, (os.cpu_count() or 2) // 2)
    p = argparse.ArgumentParser(
        prog="morvox",
        description=(
            "Toggle audio capture and transcribe with whisper.cpp, then type the "
            "transcription into the originally focused window via xdotool."
        ),
    )
    p.add_argument("--model", default=DEFAULT_MODEL,
                   help=f"Path to whisper.cpp ggml model (default: {DEFAULT_MODEL})")
    p.add_argument("--language", default="en", help="Whisper language code (default: en)")
    p.add_argument("--threads", type=int, default=default_threads,
                   help=f"Whisper thread count (default: {default_threads})")
    p.add_argument("--source", default=None,
                   help="PulseAudio/PipeWire source name (default: system default)")
    p.add_argument("--type-delay", type=int, default=1,
                   help="xdotool type --delay in ms (default: 1)")
    p.add_argument("--keep-temp", action="store_true",
                   help="Keep temporary files after typing (default: delete)")

    mode = p.add_mutually_exclusive_group()
    mode.add_argument("--status", action="store_true",
                      help="Print 'recording' or 'idle' and exit")
    mode.add_argument("--cancel", action="store_true",
                      help="Cancel any active recording without transcribing/typing")
    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    # Ensure state dir exists for any sub-action.
    _state()

    if args.status:
        return cmd_status()
    if args.cancel:
        return cmd_cancel(args)

    # Toggle behavior.
    if is_recording():
        return cmd_stop(args)
    else:
        # Clean any stale leftovers from a previous failed run before starting.
        if read_pid() is not None and not is_recording():
            _pid_file().unlink(missing_ok=True)
        return cmd_start(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
